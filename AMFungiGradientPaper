Summary Table with significant differences of Soil Properties by Region 
```{r}
library(readxl)
library(dplyr)
library(tidyr)
library(multcompView)
library(agricolae)   

#Load and subset your data
all_data <- read_excel("WorkingFile.xls")
region_data <- all_data %>% filter(Treatment == 4)

#Identify relevant columns
soil_cols <- c("Region", "Bulk_Density", "pH", "EC", "Nitrate", "Ammonium", "Total_Inorganic_N", "PMN", "Phosphate", "POXC", "MBC", "Min_C", "Clay_Content", "Sand_Content", "Normal_Precipitation_cm", "Normal_Temperature_C", "Soil_K", "Soil_Na", "Soil_Ca", "Soil_Mg", "CEC", "Soil_Zn", "Soil_Mn", "Soil_Cu", "Soil_Fe", "AMF_Colonization", "Total_Arbuscules", "Total_Hyphae", "Total_Vesicles", 
"Average_Cluster_Count", "Average_Cluster_Weight", "Average_Harvest") 
region_soil <- region_data %>% select(any_of(soil_cols))
region_soil[,-1] <- lapply(region_soil[,-1], function(x) as.numeric(as.character(x)))

soil_long <- region_soil %>%
  pivot_longer(-Region, names_to = "SoilProperty", values_to = "value") %>%
  filter(!is.na(value))

results <- soil_long %>%
    group_by(SoilProperty) %>%
    group_modify(~{
        df <- .
        # Calculate mean, SE, and sample size per region
        mns <- df %>%
            group_by(Region) %>%
            summarise(
                Mean = mean(value, na.rm = TRUE),
                SE = sd(value, na.rm = TRUE) / sqrt(n()),
                n = n()
            )
        
        # Clean region names for matching
        mns$Region_clean <- trimws(tolower(as.character(mns$Region)))
        mns$Region_clean <- gsub("\\s+", " ", mns$Region_clean)
        
        mns  # return the data frame
    }) %>%
    ungroup()

# Create "Mean ± SE" column
results <- results %>%
  mutate(Mean_SE = paste0(round(Mean,2), " ± ", round(SE,2)))

# Pivot wider for summary table
regSoil_summary_table <- results %>%
  select(SoilProperty, Region, Mean_SE) %>%
  pivot_wider(
    names_from = Region,
    values_from = Mean_SE
  )
```

