  pivot_longer(-Location, names_to = "SoilProperty", values_to = "value") %>%
  filter(!is.na(value)) %>%
  mutate(Location_clean = gsub("[ -]", "_", Location))

results <- soil_gen %>%
  group_by(SoilProperty) %>%
  group_modify(~{
    df <- .
    df <- df %>%
      mutate(
        Location_orig = as.character(Location),
        Location_safe = gsub("-", "_", Location_orig),     # remove hyphens
        Location_safe = trimws(Location_safe)
      )
    # summary by original location (for output)
    mns <- df %>%
      group_by(Location = Location_orig) %>%
      summarise(
        Mean = mean(value, na.rm = TRUE),
        SE = sd(value, na.rm = TRUE) / sqrt(n()),
        n = n(),
        .groups = "drop"
      })

# Create "Mean ± SE + letter" column
