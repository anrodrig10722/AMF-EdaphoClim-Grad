#PERMANOVA of Soil Properties 
```{r}
library(readxl)
library(dplyr)
library(vegan)
library(ggplot2)
library(ggrepel)
library(FSA)
library(permute)

all_data <- read_excel("WorkingFile.xls")
region_data <- all_data %>% filter(Treatment == 4)

# Only include soil and climate properties
region_soil <- subset(region_data, select = -c(
  forward.absolute.filepath, reverse.absolute.filepath,
  Treatment, Replicate, Vine, Rootstock, Genotype, Year_of_Planting, Berry_Type,
  Observed_Diverstiy, Chao1_Diversity, Shannon_Diversity, Evenness_Diversity,
  AMF_Colonization, Total_Hyphae, Total_Arbuscules, Total_Vesicles, Total_None,
  Average_Cluster_Count, Average_Cluster_Weight, Average_Harvest,
  N_Leaf, P_Leaf, K_Leaf, S_Leaf, B_Leaf, Ca_Leaf, Mg_Leaf, Zn_Leaf,
  Mn_Leaf, Fe_Leaf, Cu_Leaf, Vineyard_Age_yr, total_anthocyanins,
  quercetin_aglycone, quercetin_glycosides, grape_reaction_product, tannin,
  polymeric_anthocyanins, catechintannin_index, catechin, gallic_acid,
  caftaric_acid, caffeic_acid, astilbin, polymeric_anthocyaninstannin_index,
  Year_of_Sampling, Date_of_Sampling, Corrected_None, Corrected_Colonization))

region_soil$Ammonium          <- as.numeric(region_soil$Ammonium)
region_soil$Total_Inorganic_N <- as.numeric(region_soil$Total_Inorganic_N)
region_soil$PMN               <- as.numeric(region_soil$PMN)
region_soil$MBC               <- as.numeric(region_soil$MBC)
region_soil$Soil_K            <- as.numeric(region_soil$Soil_K)
region_soil$Soil_Na           <- as.numeric(region_soil$Soil_Na)

region_soil <- na.omit(region_soil)
region_soil        <- region_soil %>% select(-sampleID)

# Standardize numeric columns only
numeric_columns    <- sapply(region_soil, is.numeric)
normal_soil        <- as.data.frame(scale(region_soil[, numeric_columns]))
normal_region_soil <- cbind(region_soil[, !numeric_columns], normal_soil)

# Ensure factors
normal_region_soil$Region   <- as.factor(normal_region_soil$Region)
normal_region_soil$Location <- as.factor(normal_region_soil$Location)

# --- Global PERMANOVA ---
set.seed(123)
region_permanova <- adonis2(
  normal_soil ~ Region,
  data         = normal_region_soil,
  method       = "euclidean",
  permutations = 999)
print(region_permanova)

# --- Global betadisper (homogeneity of dispersion) ---
dist_mat_all <- vegdist(normal_soil, method = "euclidean")
bd_all       <- betadisper(dist_mat_all, group = normal_region_soil$Region)
set.seed(123)
bd_pw        <- permutest(bd_all, pairwise = TRUE, permutations = 999)
print(bd_pw)
# NOTE: permuted p-values are above the diagonal in the pairwise table.
# Pairs with significant betadisper AND significant PERMANOVA should be
# interpreted cautiously — PERMANOVA may be detecting dispersion differences
# rather than centroid differences.

# --- Pairwise PERMANOVA loop ---
set.seed(123)
groups   <- unique(as.character(normal_region_soil$Region))
pairs    <- t(combn(groups, 2))
res_list <- vector("list", nrow(pairs))

for (i in seq_len(nrow(pairs))) {
  g1 <- pairs[i, 1]; g2 <- pairs[i, 2]
  sel      <- normal_region_soil$Region %in% c(g1, g2)
  subdata  <- normal_soil[sel, , drop = FALSE]
  submeta  <- normal_region_soil[sel, ]
  subgroup <- factor(submeta$Region)
  ntab     <- table(subgroup)

  if (any(ntab < 2)) {
    res_list[[i]] <- data.frame(group1=g1, group2=g2,
                                n1=as.integer(ntab[1]), n2=as.integer(ntab[2]),
                                adonis_F=NA, adonis_R2=NA, adonis_p=NA,
                                betadisper_p=NA, note="too few samples")
    next
  }

  ad    <- adonis2(subdata ~ subgroup, method = "euclidean", permutations = 999)
  ad_F  <- ad$F[1]; ad_R2 <- ad$R2[1]; ad_p <- ad$`Pr(>F)`[1]

  dm     <- vegdist(subdata, method = "euclidean")
  bd_sub <- betadisper(dm, group = subgroup)
  bd_p   <- permutest(bd_sub, permutations = 999)$tab[1, "Pr(>F)"]

  res_list[[i]] <- data.frame(group1=g1, group2=g2,
                              n1=as.integer(ntab[1]), n2=as.integer(ntab[2]),
                              adonis_F=ad_F, adonis_R2=ad_R2, adonis_p=ad_p,
                              betadisper_p=bd_p,
                              note="exploratory - unrestricted permutations",
                              stringsAsFactors=FALSE)
}

pairwise_table <- bind_rows(res_list)
valid <- !is.na(pairwise_table$adonis_p)
pairwise_table$adonis_p_adj_BH <- NA
pairwise_table$adonis_p_adj_BH[valid] <- p.adjust(pairwise_table$adonis_p[valid], method = "BH")
print(pairwise_table)

# --- Betadisper: distances-to-centroid ---
soil_disper           <- betadisper(dist(normal_soil, method = "euclidean"),
                                    normal_region_soil$Region)
distances_to_centroid <- soil_disper$distances

shapiro_result <- shapiro.test(distances_to_centroid)
print(shapiro_result)

# Shapiro-Wilk confirms non-normality so use non-parametric test
set.seed(123)
kruskal_result <- kruskal.test(distances_to_centroid ~ normal_region_soil$Region)
print(kruskal_result)

dunn_result <- dunnTest(distances_to_centroid ~ normal_region_soil$Region,
                        method = "bonferroni")
print(dunn_result)

# --- envfit with unrestricted permutations ---
# Unrestricted permutations used because vineyard-level variables (e.g., plant variables) are invariant within vineyards, making restricted permutations
# structurally incapable of producing valid p-values for those variables
set.seed(123)
fit <- envfit(soil_disper, normal_soil, permutations = 999)
print(fit)

scaling_factor    <- 3
vectors           <- as.data.frame(fit$vectors$arrows * sqrt(fit$vectors$r)) * scaling_factor
rownames(vectors) <- gsub("Normal_", "", rownames(vectors))

# --- PCoA ---
pcoa_result <- cmdscale(dist(normal_soil, method = "euclidean"), k = 3, eig = TRUE)
pcoa_scores <- as.data.frame(pcoa_result$points)
colnames(pcoa_scores) <- c("PCoA1", "PCoA2", "PCoA3")
eigenvalues      <- pcoa_result$eig
percent_variance <- eigenvalues / sum(eigenvalues) * 100

# Use PCoA scores for plot_data 
plot_data     <- data.frame(pcoa_scores, Region = normal_region_soil$Region)
region_colors <- c("Central CA" = "#F8766D", "Northern CA" = "#00BFC4", "Oregon" = "#41ab5d")

# Plot with all vectors
ggplot(plot_data, aes(x = PCoA1, y = PCoA2, color = Region)) +
  geom_point() +
  stat_ellipse() +
  theme_minimal() +
  labs(x = paste0("PCoA1 (", round(percent_variance[1], 1), "%)"),
       y = paste0("PCoA2 (", round(percent_variance[2], 1), "%)"),
       color = "Region") +
  scale_color_manual(values = region_colors) +
  geom_segment(data = vectors, aes(x = 0, xend = PCoA1, y = 0, yend = PCoA2),
               arrow = arrow(length = unit(0.2, "cm")), inherit.aes = FALSE, color = "black") +
  geom_text_repel(data = vectors, aes(x = PCoA1, y = PCoA2, label = rownames(vectors)),
                  size = 3,
                  box.padding = 0.3,
                  point.padding = 0.2,
                  max.overlaps = Inf,
                  segment.color = "grey50",
                  segment.size = 0.3,
                  inherit.aes = FALSE)

# Top 15 vectors only
top_vectors       <- as.data.frame(fit$vectors$arrows * sqrt(fit$vectors$r))
top_vectors       <- top_vectors[order(fit$vectors$r, decreasing = TRUE), ][1:15, ] * scaling_factor
top_vectors$label <- gsub("Normal_", "", rownames(top_vectors))

a2 <- ggplot(plot_data, aes(x = PCoA1, y = PCoA2, color = Region)) +
  geom_point() +
  stat_ellipse() +
  theme_minimal() +
  labs(x = paste0("PCoA1 (", round(percent_variance[1], 1), "%)"),
       y = paste0("PCoA2 (", round(percent_variance[2], 1), "%)"),
       color = "Region") +
  scale_color_manual(values = region_colors) +
  geom_segment(data = top_vectors, aes(x = 0, xend = PCoA1, y = 0, yend = PCoA2),
               arrow = arrow(length = unit(0.2, "cm")), inherit.aes = FALSE, color = "black") +
  geom_text_repel(data = top_vectors, aes(x = PCoA1, y = PCoA2, label = label),
                  size = 3.5,
                  box.padding = 0.3,
                  point.padding = 0.2,
                  max.overlaps = Inf,
                  segment.color = "grey50",
                  segment.size = 0.3,
                  inherit.aes = FALSE)
print(a2)
```

